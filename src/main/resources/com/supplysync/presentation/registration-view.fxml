<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.supplysync.presentation.RegistrationController" styleClass="auth-root" stylesheets="@auth.css">
    <VBox HBox.hgrow="ALWAYS" styleClass="auth-left" spacing="10.0">
        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
        </padding>
        <Label text="SupplySync" styleClass="brand-title"/>
        <Label text="Wholesale Distribution Platform" styleClass="brand-subtitle"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Label text="Create your team account and start managing your distribution workflow." styleClass="left-caption" wrapText="true"/>
    </VBox>

    <VBox prefWidth="560.0" spacing="12.0" styleClass="auth-right">
        <padding>
            <Insets top="34.0" right="36.0" bottom="34.0" left="36.0"/>
        </padding>
        <HBox alignment="CENTER_RIGHT">
        </HBox>
        <Label text="Create account" styleClass="auth-title"/>
        <Label text="Set up your SupplySync workspace." styleClass="auth-subtitle"/>

        <HBox spacing="10.0">
            <VBox HBox.hgrow="ALWAYS" spacing="6.0">
                <Label text="First Name" styleClass="field-label"/>
                <TextField fx:id="firstNameField" promptText="First name"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="6.0">
                <Label text="Last Name" styleClass="field-label"/>
                <TextField fx:id="lastNameField" promptText="Last name"/>
            </VBox>
        </HBox>

        <VBox spacing="6.0">
            <Label text="Work Email" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="name@company.com"/>
        </VBox>

        <VBox spacing="6.0">
            <Label text="Company Name" styleClass="field-label"/>
            <TextField fx:id="companyField" promptText="Company"/>
        </VBox>

        <HBox spacing="10.0">
            <VBox HBox.hgrow="ALWAYS" spacing="6.0">
                <Label text="Password" styleClass="field-label"/>
                <StackPane>
                    <PasswordField fx:id="passwordField" promptText="Create password"/>
                    <TextField fx:id="passwordPlainField" promptText="Create password" visible="false" managed="false"/>
                </StackPane>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="6.0">
                <Label text="Confirm Password" styleClass="field-label"/>
                <StackPane>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"/>
                    <TextField fx:id="confirmPlainField" promptText="Confirm password" visible="false" managed="false"/>
                </StackPane>
            </VBox>
        </HBox>

        <CheckBox fx:id="showPasswordCheck" text="Show passwords"/>
        <CheckBox fx:id="agreeCheckBox" text="I agree to the Terms and Privacy Policy"/>
        <Button text="Create Account" onAction="#createAccount" styleClass="primary-btn"/>

        <HBox alignment="CENTER">
            <Label text="Already have an account? " styleClass="muted"/>
            <Hyperlink text="Sign in" onAction="#openLogin"/>
        </HBox>
    </VBox>
</HBox>
