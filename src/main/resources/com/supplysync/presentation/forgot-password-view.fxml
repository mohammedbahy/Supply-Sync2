<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.supplysync.presentation.ForgotPasswordController" styleClass="auth-root" stylesheets="@auth.css">
    <VBox HBox.hgrow="ALWAYS" styleClass="auth-left" spacing="10.0">
        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
        </padding>
        <Label text="SupplySync" styleClass="brand-title"/>
        <Label text="Wholesale Distribution Platform" styleClass="brand-subtitle"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Label text="Reset your password to regain access to your account." styleClass="left-caption" wrapText="true"/>
    </VBox>

    <VBox prefWidth="520.0" spacing="14.0" styleClass="auth-right">
        <padding>
            <Insets top="40.0" right="36.0" bottom="40.0" left="36.0"/>
        </padding>
        <Label text="Reset Password" styleClass="auth-title"/>
        <Label text="Enter your email and new password." styleClass="auth-subtitle"/>

        <VBox spacing="6.0">
            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="name@company.com"/>
        </VBox>

        <VBox spacing="6.0">
            <Label text="New Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="Enter new password"/>
        </VBox>

        <VBox spacing="6.0">
            <Label text="Confirm New Password" styleClass="field-label"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password"/>
        </VBox>

        <Button text="Reset Password" onAction="#resetPassword" styleClass="primary-btn"/>

        <HBox alignment="CENTER">
            <Hyperlink text="Back to Login" onAction="#openLogin"/>
        </HBox>
    </VBox>
</HBox>
