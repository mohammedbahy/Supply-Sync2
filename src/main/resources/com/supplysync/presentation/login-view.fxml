<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.supplysync.presentation.LoginController" styleClass="auth-root" stylesheets="@auth.css">
    <VBox HBox.hgrow="ALWAYS" styleClass="auth-left" spacing="10.0">
        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
        </padding>
        <Label text="SupplySync" styleClass="brand-title"/>
        <Label text="Wholesale Distribution Platform" styleClass="brand-subtitle"/>
        <Region VBox.vgrow="ALWAYS"/>
        <Label text="Manage inventory, orders, and marketer operations from one place." styleClass="left-caption" wrapText="true"/>
    </VBox>

    <VBox prefWidth="520.0" spacing="14.0" styleClass="auth-right">
        <padding>
            <Insets top="40.0" right="36.0" bottom="40.0" left="36.0"/>
        </padding>
        <HBox alignment="CENTER_RIGHT">
        </HBox>
        <Label text="Welcome back" styleClass="auth-title"/>
        <Label text="Sign in to continue to SupplySync." styleClass="auth-subtitle"/>

        <VBox spacing="6.0">
            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="name@company.com"/>
        </VBox>

        <VBox spacing="6.0">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="Enter your password"/>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <CheckBox text="Remember me"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink text="Forgot password?" onAction="#openForgotPassword"/>
        </HBox>

        <Button text="Sign In" onAction="#signIn" styleClass="primary-btn"/>

        <HBox alignment="CENTER">
            <Label text="Don't have an account? " styleClass="muted"/>
            <Hyperlink text="Create account" onAction="#openRegistration"/>
        </HBox>
    </VBox>
</HBox>
